# Server
PORT=5000
NODE_ENV=development
ENABLE_RATE_LIMIT_IN_DEV=false
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=20

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<app-name>
MONGODB_DB_NAME=impactscore

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Blockchain (Polygon Mumbai)
RPC_URL=https://rpc-mumbai.maticvigil.com
BACKEND_WALLET_PRIVATE_KEY=0x...

# Contract addresses (from deploy output)
CONTRACT_ACTIVITY_REGISTRY=0x...
CONTRACT_IMPACT_SCORE=0x...
CONTRACT_LOAN_MANAGER=0x...

# Pinata IPFS credentials (set either JWT OR API key/secret)
PINATA_JWT=
PINATA_API_KEY=
PINATA_API_SECRET=

# Optional custom gateway base (default: https://gateway.pinata.cloud/ipfs)
IPFS_GATEWAY_BASE=
