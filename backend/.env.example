# Server
PORT=5000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/impactscore

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Blockchain (Polygon Mumbai)
RPC_URL=https://rpc-mumbai.maticvigil.com
BACKEND_WALLET_PRIVATE_KEY=your-backend-wallet-private-key

# Contract addresses (from deploy output)
CONTRACT_ACTIVITY_REGISTRY=0x...
CONTRACT_IMPACT_SCORE=0x...
CONTRACT_LOAN_MANAGER=0x...

# IPFS (Web3.Storage or Pinata)
IPFS_API_KEY=your-ipfs-api-key
IPFS_API_SECRET=your-ipfs-api-secret

# Optional: Pinata
PINATA_JWT=your-pinata-jwt
